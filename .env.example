# .env.local — copy this file and fill in your values
# Never commit .env.local to source control

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────
# Used in auth email redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In production: NEXT_PUBLIC_SITE_URL=https://hiveandbloom.com
